# === DocuChat RAG Backend — Environment Variables ===
# Copy this file to `.env` and fill in your real keys.

# --- Pinecone (Vector Database) ---
PINECONE_API_KEY=your_pinecone_api_key_here

# --- Groq (LLM for chat answers) ---
GROQ_API_KEY=your_groq_api_key_here

# --- LangSmith (Monitoring & Tracing — Optional but recommended) ---
# Sign up free at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=docuchat-rag

# --- Frontend Origin (for CORS in production) ---
FRONTEND_URL=http://localhost:5173

# --- Keep-Alive (prevents Render free tier cold starts) ---
# Set this to your Render service URL after deploying (e.g. https://docuchat-rag-api.onrender.com)
# Leave empty for local development.
RENDER_EXTERNAL_URL=
